@page "/login"
@layout EmptyLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using SmartDanfe.WebApp.Models
@using Syncfusion.Blazor.Notifications

@inject NavigationManager Navigation
@* @inject ITenantService TenantService *@
@* @inject IAuthenticationService AuthenticationService *@

<PageTitle>SmartDanfe ERP - Login</PageTitle>

<div class="login-wrapper">

    <div class="login-page">

        <!-- Full-bleed banner — covers entire left background -->
        <img src="/Images/smartdanfe-banner.png"
             class="banner-img"
             alt="SmartDanfe ERP" />

        <!-- ========================================= -->
        <!-- RIGHT PANEL — floats over banner          -->
        <!-- ========================================= -->

        <section class="right-panel">

            <div class="login-card">

                <!-- Tenant Header -->
                <div class="tenant-header">
                    <img src="@CompanyLogo"
                         class="tenant-logo"
                         alt="@CompanyName" />
                    <span class="tenant-name">@CompanyName</span>
                </div>

                <!-- Welcome -->
                <div class="welcome-section">
                    <h2>Welcome back!</h2>
                    <p>Sign in to continue to SmartDanfe ERP</p>
                </div>

                <!-- Login Form -->
                <EditForm Model="@Model" OnValidSubmit="OnLoginAsync">

                    <DataAnnotationsValidator />

                    <!-- Username -->
                    <div class="form-group">
                        <label class="field-label">Username</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                            </span>
                            <InputText class="field-input"
                                       placeholder="Enter your username"
                                       @bind-Value="Model.Username" />
                        </div>
                        <ValidationMessage For="@(() => Model.Username)" class="validation-message" />
                    </div>

                    <!-- Password -->
                    <div class="form-group">
                        <label class="field-label">Password</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            </span>
                            <InputText class="field-input"
                                       placeholder="Enter your password"
                                       type="@(ShowPassword ? "text" : "password")"
                                       @bind-Value="Model.Password" />
                            <button type="button"
                                    class="password-toggle"
                                    @onclick="TogglePassword"
                                    title="@(ShowPassword ? "Hide password" : "Show password")">
                                @if (ShowPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                        <line x1="1" y1="1" x2="23" y2="23" />
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                        <circle cx="12" cy="12" r="3" />
                                    </svg>
                                }
                            </button>
                        </div>
                        <ValidationMessage For="@(() => Model.Password)" class="validation-message" />
                    </div>

                    <!-- Options Row -->
                    <div class="login-options">
                        <label class="remember-me">
                            <input type="checkbox"
                                   class="remember-checkbox"
                                   @bind="Model.RememberMe" />
                            <span>Remember me</span>
                        </label>
                        <button type="button" class="forgot-password-button">
                            Forgot password?
                        </button>
                    </div>

                    <!-- Sign In -->
                    <button type="submit"
                            class="login-button"
                            disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border"></span>
                            <span>Signing In...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 class="btn-arrow">
                                <line x1="5" y1="12" x2="19" y2="12" />
                                <polyline points="12 5 19 12 12 19" />
                            </svg>
                        }
                    </button>

                </EditForm>

                <!-- Help -->
                <div class="help-row">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                         class="help-icon">
                        <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
                        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z" />
                        <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
                    </svg>
                    <span>Need help? Contact <a href="mailto:support@smartdanfe.com" class="support-link">support</a></span>
                </div>

            </div>

        </section>

    </div>

    <!-- ========================================= -->
    <!-- GLOBAL FOOTER BAR                         -->
    <!-- ========================================= -->

    <footer class="global-footer">
        <span class="footer-security">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                 class="footer-shield">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            Your data is secure and protected
        </span>
        <span class="footer-copy">© 2026 SmartDanfe ERP. All rights reserved.</span>
        <span class="footer-links">
            <a href="#">Privacy Policy</a>
            <span class="footer-sep">|</span>
            <a href="#">Terms of Use</a>
        </span>
    </footer>

</div>

<SfToast @ref="Toast"></SfToast>

@code {
    private readonly LoginModel Model = new();

    private SfToast? Toast;

    private bool IsLoading;

    private bool ShowPassword = false;

    private string CompanyName = "SmartDanfe Pharmaceuticals";
    private string CompanyLogo = "/Images/tenant-logo.png";

    protected override async Task OnInitializedAsync()
    {
        // Future implementation
        // var tenant = await TenantService.GetCurrentTenantAsync();
        // CompanyName = tenant.CompanyName;
        // CompanyLogo = tenant.LogoUrl;

        await Task.CompletedTask;
    }

    private void TogglePassword()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task OnLoginAsync()
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            // Future implementation
            // var result = await AuthenticationService.LoginAsync(Model);

            await Task.Delay(1000);

            Navigation.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            if (Toast != null)
            {
                await Toast.ShowAsync(new ToastModel
                {
                    Title = "Login Failed",
                    Content = ex.Message,
                    CssClass = "e-toast-danger"
                });
            }
        }
        finally
        {
            IsLoading = false;
        }
    }
}
